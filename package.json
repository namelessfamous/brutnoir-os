{
  "name": "@namelessfamous/brutnoir-os",
  "version": "0.1.0",
  "description": "Neobrutal Noir design system — Vintage Mac OS × Windows 95 × modern darkness",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "neobrutal",
    "noir",
    "nameless-famous"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namelessfamous/brutnoir-os.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
